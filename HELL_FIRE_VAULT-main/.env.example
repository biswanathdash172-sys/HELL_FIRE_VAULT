# =====================================================================
# HELLFIRE VAULT — Environment Variables Template
# =====================================================================
# Rename this file to .env and fill in your actual values.
# This file is safe to commit. .env is NOT.

# SUPABASE — https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# GOOGLE GEMINI AI — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# FLASK
FLASK_SECRET_KEY=change-this-to-a-random-secret-string
FLASK_ENV=development
